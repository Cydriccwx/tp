@startuml
hide footbox
skinparam Style strictuml
skinparam SequenceMessageAlign center

participant "user" as User
participant ":TradeLog" as TradeLog
participant ":Parser" as Parser
participant "cc:CompareCommand" as CompareCommand
participant "tl:TradeList" as TradeList
participant "t:Trade" as Trade
participant ":Ui" as Ui

User -> TradeLog : input "compare"
activate TradeLog

TradeLog -> Parser : parseCommand("compare")
activate Parser
Parser -> CompareCommand : new CompareCommand()
activate CompareCommand
Parser --> TradeLog : cc
deactivate Parser

TradeLog -> CompareCommand : execute(tradeList, ui, storage)

CompareCommand -> TradeList : isEmpty()
activate TradeList
TradeList --> CompareCommand : isEmpty
deactivate TradeList

alt tradeList is empty
    CompareCommand -> Ui : showSummaryEmpty()
    activate Ui
    Ui --> CompareCommand
    deactivate Ui
else tradeList is not empty
    loop for each trade
        CompareCommand -> TradeList : getTrade(i)
        activate TradeList
        TradeList --> CompareCommand : t
        deactivate TradeList

        CompareCommand -> Trade : getStrategy()
        activate Trade
        Trade --> CompareCommand : strategy
        deactivate Trade

        CompareCommand -> Trade : getRiskRewardRatio()
        activate Trade
        Trade --> CompareCommand : rr
        deactivate Trade

        note over CompareCommand
            looks up or creates the
            corresponding StrategyStats
            entry and accumulates rr
        end note
    end

    CompareCommand -> Ui : showStrategyComparison(strategyComparison)
    activate Ui
    Ui --> CompareCommand
    deactivate Ui
end

CompareCommand --> TradeLog
deactivate CompareCommand
TradeLog --> User
deactivate TradeLog
@enduml